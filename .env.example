# Supabase project URL — looks like https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-only, never expose to the browser.
# Used by the one-time JSON import endpoint.
SUPABASE_SERVICE_ROLE_KEY=

# Vercel API tokens for deployment sync (daily cron)
VERCEL_API_TOKEN=
VERCEL_API_TOKEN_TEAM=

# Cron job secret (Vercel Cron sends this as Authorization header)
CRON_SECRET=

# Telegram bot for deployment notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
