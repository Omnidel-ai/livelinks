# Supabase project URL — looks like https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-only, never expose to the browser.
# Used by the one-time JSON import endpoint.
SUPABASE_SERVICE_ROLE_KEY=
